FROM golang:1.23-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      jq \
      sqlite3 \
      docker.io \
      python3 \
      python3-pip \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /work

CMD ["bash", "test/run-e2e.sh"]
