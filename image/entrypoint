#!/usr/bin/env bash
set -euo pipefail

if [[ "${AGENTCTL_DEBUG:-}" == "1" ]]; then
  set -x
fi

# container-and-image.md §2.6 step 5: re-route the SDK history dir onto the
# session volume so idle-resume / restart preserves conversation history.
mkdir -p /work/.claude/projects
ln -sfn /work/.claude /home/agent/.claude

# Expose the per-session skills snapshot under ~/.claude/skills so the
# claude-agent-sdk's filesystem discovery (which reads `~/.claude/skills/`
# and `./.claude/skills/`) finds them. The host bind-mounts the snapshot at
# /skills read-only; ~/.claude is the entrypoint-managed symlink above, so
# /work/.claude/skills is what both the user-scope and project-scope (cwd=/work)
# settings resolve to. We only refresh a pre-existing symlink (which we placed
# in a prior run) — a real directory under .claude/skills is left alone to
# avoid clobbering anything the developer wrote into the session volume by
# hand.
if [[ -d /skills ]]; then
  if [[ -L /work/.claude/skills ]]; then
    rm -f /work/.claude/skills
  fi
  if [[ ! -e /work/.claude/skills ]]; then
    ln -sfn /skills /work/.claude/skills
  fi
fi

# §2.5: PAT-based git credentials. The credentials file is mode 0600 and lives
# on the session volume; the helper config tells git to read from it. We use
# `git config --global` rather than writing the config file directly so git
# picks it up regardless of XDG_CONFIG_HOME — `git config --global` writes to
# the location git itself reads from on this system.
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  mkdir -p /work/.config/git
  (umask 077 && printf 'https://x-access-token:%s@github.com\n' "${GITHUB_TOKEN}" \
    > /work/.config/git/credentials)
  git config --global credential.helper "store --file=/work/.config/git/credentials"
  # `gh` reads GITHUB_TOKEN, but some tooling (and gh's own preference order)
  # looks for GH_TOKEN first; export both so subprocesses inherit them.
  export GH_TOKEN="${GITHUB_TOKEN}"
fi

if [[ -n "${GIT_AUTHOR_NAME:-}" ]]; then
  git config --global user.name "${GIT_AUTHOR_NAME}" || true
fi
if [[ -n "${GIT_AUTHOR_EMAIL:-}" ]]; then
  git config --global user.email "${GIT_AUTHOR_EMAIL}" || true
fi

exec /opt/agentctl/venv/bin/python -m shim "$@"
